# Network used by the frontend and scripts.
VITE_GENLAYER_NETWORK="testnet-bradbury"

# Deployed Quorum contract address.
VITE_GENLAYER_CONTRACT_ADDRESS="0xac25788f412Ab7A271799262CdbD65F1Eca1bEC3"

# Optional RPC override. Leave blank to use the GenLayer chain default.
VITE_GENLAYER_RPC_URL=""

# Optional browser/dev signing key for frontend writes.
# Do not commit a real private key.
VITE_GENLAYER_ACCOUNT_PRIVATE_KEY=""

# Required only for deployment and live-test scripts.
# Do not commit a real private key.
GENLAYER_PRIVATE_KEY=""

# Optional deploy-time board topic.
MODERATION_TOPIC="GenLayer and blockchain development"
